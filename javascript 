// Tailwind script already included in HTML
function navigateTo(section) {
    document.querySelectorAll('.section').forEach(s => s.classList.add('hidden'));
    document.getElementById(section + '-section').classList.remove('hidden');
    
    // Highlight nav
    document.querySelectorAll('.nav-link').forEach(link => link.classList.remove('text-amber-400'));
    document.getElementById('nav-' + section).classList.add('text-amber-400');
}

let soundEnabled = true;

function toggleSound() {
    soundEnabled = !soundEnabled;
    document.getElementById('sound-btn').textContent = soundEnabled ? '🔊' : '🔇';
}

// Simple click sound simulation
function playSound(type) {
    if (!soundEnabled) return;
    const audio = new Audio();
    if (type === 'match') audio.src = 'https://freesound.org/data/previews/276/276951_5123854-lq.mp3'; // replace with real short sounds if you host them
    audio.volume = 0.3;
    audio.play().catch(() => {});
}

// Select planet
function selectPlanet(el) {
    const names = ["Mia - Coding", "Alex - UI/UX Design", "Jordan - Video Editing", "Taylor - Music", "Sam - Data Science"];
    const randomName = names[Math.floor(Math.random() * names.length)];
    
    document.getElementById('modal-title').textContent = randomName;
    document.getElementById('modal-desc').innerHTML = `
        <p class="mb-4">Skill Level: Expert</p>
        <p>Looking to connect with students who want to learn this skill or collaborate.</p>
        <button onclick="connectWithStudent()" class="mt-6 w-full py-4 bg-emerald-500 hover:bg-emerald-600 rounded-2xl">Connect Now</button>
    `;
    document.getElementById('planet-modal').classList.remove('hidden');
    playSound('match');
}

function closeModal() {
    document.getElementById('planet-modal').classList.add('hidden');
}

function showSunModal() {
    document.getElementById('sun-modal').classList.remove('hidden');
}

function closeSunModal() {
    document.getElementById('sun-modal').classList.add('hidden');
}

function setOfferLevel(btn) {
    document.querySelectorAll('.level-btn').forEach(b => b.classList.remove('border-amber-400', 'bg-amber-400/10'));
    btn.classList.add('border-amber-400', 'bg-amber-400/10');
}

